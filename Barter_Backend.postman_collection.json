{
  "info": {
    "name": "Barter Backend API",
    "description": "API collection for Barter Backend with Auth, Users, and Products",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Request OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"user@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/request-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "request-otp"
              ]
            },
            "description": "Request OTP for email or phone number\n\nIdentifier can be:\n- Email: user@example.com\n- Phone: 10-digit number (e.g., 9876543210)"
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"user@example.com\",\n  \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "verify-otp"
              ]
            },
            "description": "Verify OTP code and get authentication tokens\n\nRequired:\n- identifier: Email or 10-digit phone\n- code: 6-digit OTP\n\nSave the accessToken to the postman variable {{accessToken}} for authenticated requests"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "description": "JWT Access Token from auth/verify-otp"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "profile"
              ]
            },
            "description": "Get authenticated user profile (requires valid access token)"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "categories"
              ]
            },
            "description": "Get all categories (PUBLIC)"
          }
        },
        {
          "name": "Get Category By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/categories/770e8400-e29b-41d4-a716-446655440002",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "categories",
                "770e8400-e29b-41d4-a716-446655440002"
              ]
            },
            "description": "Get a single category by ID with products and subcategories (PUBLIC)"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Admin-Key",
                "value": "{{adminKey}}",
                "description": "Admin API key - default dev key: admin123"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\",\n  \"parentCategoryId\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "categories"
              ]
            },
            "description": "Create a new category (ADMIN ONLY)\n\nRequired headers:\n- X-Admin-Key: Your admin key\n\nRequired fields:\n- name: string (max 100 chars)\n\nOptional fields:\n- parentCategoryId: UUID of parent category for nested categories"
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Admin-Key",
                "value": "{{adminKey}}",
                "description": "Admin API key"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics & Gadgets\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/categories/770e8400-e29b-41d4-a716-446655440002",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "categories",
                "770e8400-e29b-41d4-a716-446655440002"
              ]
            },
            "description": "Update a category (ADMIN ONLY)\n\nOptional fields:\n- name: string\n- parentCategoryId: UUID\n\nValidation:\n- Cannot create circular parent references\n- Category name must be unique"
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-Admin-Key",
                "value": "{{adminKey}}",
                "description": "Admin API key"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/categories/770e8400-e29b-41d4-a716-446655440002",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "categories",
                "770e8400-e29b-41d4-a716-446655440002"
              ]
            },
            "description": "Delete a category (ADMIN ONLY)\n\nRestrictions:\n- Cannot delete if it has child categories\n- Cannot delete if it has associated products"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/products?status=ACTIVE",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "ACTIVE",
                  "disabled": true
                },
                {
                  "key": "categoryId",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "ownerId",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                }
              ]
            },
            "description": "Get all products with optional filters (PUBLIC)\n\nQuery Parameters (all optional):\n- status: ACTIVE | RESERVED | EXCHANGED | REMOVED\n- categoryId: UUID\n- ownerId: UUID\n- search: Search term for title or description"
          }
        },
        {
          "name": "Get Product By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/products/660e8400-e29b-41d4-a716-446655440001",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products",
                "660e8400-e29b-41d4-a716-446655440001"
              ]
            },
            "description": "Get a single product by ID with all images (PUBLIC)"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "description": "JWT Access Token from auth/verify-otp"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Vintage Camera\",\n  \"description\": \"A beautiful vintage camera in good condition\",\n  \"categoryId\": \"770e8400-e29b-41d4-a716-446655440002\",\n  \"status\": \"ACTIVE\",\n  \"requestByMoney\": false,\n  \"locationName\": \"New York, NY\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060,\n  \"isPreOwned\": true,\n  \"lifecycleVersion\": 1,\n  \"isListed\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            },
            "description": "Create a new product (PROTECTED - requires auth)\n\nRequired fields:\n- title: string\n\nOptional fields:\n- description: string\n- categoryId: UUID\n- status: ACTIVE | RESERVED | EXCHANGED | REMOVED (default: ACTIVE)\n- requestByMoney: boolean (default: false)\n- locationName: string\n- latitude: number\n- longitude: number\n- isPreOwned: boolean (default: false)\n- lifecycleVersion: positive integer (default: 1)\n- isListed: boolean (default: true)\n\nNote: currentOwnerId is automatically set from authenticated user token"
          }
        },
        {
          "name": "Generate Pre-signed URLs for Images",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "description": "JWT Access Token from auth/verify-otp"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fileNames\": [\"image1.jpg\", \"image2.png\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products/660e8400-e29b-41d4-a716-446655440001/images/presigned",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products",
                "660e8400-e29b-41d4-a716-446655440001",
                "images",
                "presigned"
              ]
            },
            "description": "Generate pre-signed URLs for direct S3 image uploads (PROTECTED - requires auth)\n\nRequest Body:\n- fileNames: Array of strings (1-6 file names with extensions)\n\nResponse: Array of objects with signedUrl, publicUrl, storageKey, fileName\n\nUse the signedUrl to upload files directly to S3. URLs expire in 1 hour."
          }
        },
        {
          "name": "Add Uploaded Images to Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "description": "JWT Access Token from auth/verify-otp"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"images\": [\n    {\n      \"storageKey\": \"products/660e8400-e29b-41d4-a716-446655440001/1234567890-abc123.jpg\",\n      \"url\": \"https://your-bucket.s3.region.amazonaws.com/products/660e8400-e29b-41d4-a716-446655440001/1234567890-abc123.jpg\",\n      \"isPrimary\": true\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products/660e8400-e29b-41d4-a716-446655440001/images",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products",
                "660e8400-e29b-41d4-a716-446655440001",
                "images"
              ]
            },
            "description": "Register uploaded images in the database after direct S3 upload (PROTECTED - requires auth)\n\nRequest Body:\n- images: Array of objects\n  - storageKey: S3 key from pre-signed URL response\n  - url: Public S3 URL\n  - isPrimary: boolean (true for first image)\n\nCall this after successfully uploading to the pre-signed URLs.\n\nNote: Only product owner can add images"
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "description": "JWT Access Token from auth/verify-otp"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/products/660e8400-e29b-41d4-a716-446655440001",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products",
                "660e8400-e29b-41d4-a716-446655440001"
              ]
            },
            "description": "Delete a product and all associated images from S3 (PROTECTED)\n\nNote: Only product owner can delete their products"
          }
        },
        {
          "name": "Delete Product Image",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "description": "JWT Access Token from auth/verify-otp"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/products/660e8400-e29b-41d4-a716-446655440001/images/880e8400-e29b-41d4-a716-446655440003",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products",
                "660e8400-e29b-41d4-a716-446655440001",
                "images",
                "880e8400-e29b-41d4-a716-446655440003"
              ]
            },
            "description": "Delete a specific image from a product (PROTECTED)\n\nPath Parameters:\n- productId: UUID of the product\n- imageId: UUID of the image to delete\n\nNote: Only product owner can delete images from their products"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000",
      "type": "string",
      "description": "Base URL for the API"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string",
      "description": "JWT access token from verify-otp response. Copy and paste the token here after authentication."
    }
  ]
}
