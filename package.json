{
  "name": "codename-barter",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "prepare": "node -e \"if (process.env.CI === 'true' || process.env.NODE_ENV === 'production') process.exit(0); try { require('child_process').execSync('npx husky install', { stdio: 'inherit' }); } catch (_) { process.exit(0); }\"",
    "build": "tsc",
    "start": "npm run build && node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "lint": "eslint --config eslint.config.cjs --ext .ts,.tsx src",
    "lint:fix": "eslint --config eslint.config.cjs --ext .ts,.tsx src --fix",
    "format": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "lint-staged": "lint-staged",
    "test": "echo \"Error: no test specified\" && exit 1",
    "generate-admin-key": "node scripts/generate-admin-key.js"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1015.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "resend": "^6.9.4",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/cors": "^2.8.12",
    "@types/express": "^4.17.17",
    "@types/express-rate-limit": "^5.0.0",
    "@types/helmet": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/pino": "^7.0.5",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "husky": "^9.0.0",
    "lint-staged": "^14.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "npm run lint:fix",
      "npm run format:fix"
    ],
    "src/**/*.{json,md}": [
      "npm run format:fix"
    ]
  }
}
