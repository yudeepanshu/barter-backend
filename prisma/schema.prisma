generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String  @id @default(uuid())
  userName        String
  mobileNumber    String?  @unique
  email           String? @unique
  profilePicture  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contactPreference UserContactPreference?
  products          Product[] @relation("OwnerProducts")
  ownershipHistory  ProductOwnershipHistory[]
  buyRequests       Request[] @relation("RequestBuyer")
  sellRequests      Request[] @relation("RequestSeller")
  offersMade        RequestOffer[] @relation("RequestOfferByUser")
  reservationsAsBuyer ProductReservation[] @relation("ProductReservationBuyer")
  reservationsAsSeller ProductReservation[] @relation("ProductReservationSeller")
  transactionsAsBuyer Transaction[] @relation("TransactionBuyer")
  transactionsAsSeller Transaction[] @relation("TransactionSeller")
  generatedTransactionOtps TransactionOTP[] @relation("TransactionOtpGeneratedFor")
}

model Category {
  id               String    @id @default(uuid())
  name             String    @unique
  parentCategoryId String?   

  parentCategory Category?   @relation("CategoryParent", fields: [parentCategoryId], references: [id])
  children      Category[]   @relation("CategoryParent")
  products       Product[]
}

model Product {
  id               String   @id @default(uuid())
  title            String
  description      String?
  categoryId       String?
  status           String   @default("ACTIVE")
  requestByMoney   Boolean  @default(false)
  isFree           Boolean  @default(false)
  currentOwnerId   String
  productImages    ProductImage[]
  locationName     String?
  latitude         Float?
  longitude        Float?
  overrideCount    Int      @default(0)
  lastOverrideAt   DateTime?
  cooldownUntil    DateTime?
  isPreOwned       Boolean  @default(false)
  lastExchangedAt  DateTime?
  exchangeCount    Int      @default(0)
  lifecycleVersion Int      @default(1)
  isListed         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  owner    User     @relation("OwnerProducts", fields: [currentOwnerId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
  ownershipHistory ProductOwnershipHistory[]
  requests         Request[]
  reservations     ProductReservation[]
  offeredInRequests RequestOfferProduct[]
  visibleInRequests RequestVisibleProduct[]
  transactions      Transaction[]

  @@index([status, isListed, createdAt, id], name: "product_list_cursor_idx")
  @@index([latitude, longitude], name: "product_location_idx")
}

model ProductImage {
  id         String   @id @default(uuid())
  productId  String
  url        String
  storageKey String
  isPrimary  Boolean  @default(false)
  width      Int?
  height     Int?
  createdAt  DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id])
}

model ProductOwnershipHistory {
  id          String   @id @default(uuid())
  productId   String
  ownerId     String
  acquiredAt  DateTime @default(now())
  releasedAt  DateTime?

  product Product @relation(fields: [productId], references: [id])
  owner   User    @relation(fields: [ownerId], references: [id])
}

model UserContactPreference {
  id         String @id @default(uuid())
  userId     String @unique
  allowPhone Boolean
  allowEmail Boolean

  user User @relation(fields: [userId], references: [id])
}

model Request {
  id                 String   @id @default(uuid())
  productId          String
  buyerId            String
  sellerId           String
  status             String   @default("PENDING")
  currentTurn        String   @default("SELLER")
  allowProductAccess Boolean  @default(false)
  message            String?
  contactPreference  String   @default("PHONE")
  lifecycleVersion   Int
  expiresAt          DateTime?
  updateCount        Int      @default(0)
  cancelledById      String?
  cancelledByRole    String?
  cancelledReason    String?
  acceptedOfferId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  product         Product                @relation(fields: [productId], references: [id])
  buyer           User                   @relation("RequestBuyer", fields: [buyerId], references: [id])
  seller          User                   @relation("RequestSeller", fields: [sellerId], references: [id])
  offers          RequestOffer[]
  visibleProducts RequestVisibleProduct[]
  reservations   ProductReservation[]
  transactions    Transaction[]

  @@unique([productId, buyerId, sellerId], name: "request_unique_buyer_product_seller")
  @@index([productId, status], name: "request_product_status_idx")
  @@index([buyerId, status], name: "request_buyer_status_idx")
  @@index([sellerId, status], name: "request_seller_status_idx")
}

model RequestOffer {
  id               String   @id @default(uuid())
  requestId        String
  offeredById      String
  lifecycleVersion Int
  type             String
  offeredAmount    Decimal? @db.Decimal(12, 2)
  status           String   @default("ACTIVE")
  createdAt        DateTime @default(now())

  request         Request               @relation(fields: [requestId], references: [id])
  offeredBy       User                  @relation("RequestOfferByUser", fields: [offeredById], references: [id])
  offeredProducts RequestOfferProduct[]
  reservations    ProductReservation[]
  transactions    Transaction[]

  @@index([requestId, status], name: "request_offer_request_status_idx")
}

model ProductReservation {
  id             String   @id @default(uuid())
  productId      String
  requestId      String
  offerId        String
  buyerId        String
  sellerId       String
  isContactVisible Boolean @default(false)
  status         String   @default("ACTIVE")
  cancelledReason String?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
  request Request @relation(fields: [requestId], references: [id])
  offer   RequestOffer @relation(fields: [offerId], references: [id])
  buyer   User @relation("ProductReservationBuyer", fields: [buyerId], references: [id])
  seller  User @relation("ProductReservationSeller", fields: [sellerId], references: [id])
  transaction Transaction?

  @@unique([productId], name: "product_single_active_reservation")
  @@index([buyerId, status], name: "reservation_buyer_status_idx")
  @@index([sellerId, status], name: "reservation_seller_status_idx")
}

model Transaction {
  id             String   @id @default(uuid())
  reservationId  String   @unique
  productId      String
  requestId      String
  offerId        String
  buyerId        String
  sellerId       String
  status         String   @default("INITIATED")
  initiatedAt    DateTime @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?
  cancelledReason String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  reservation ProductReservation @relation(fields: [reservationId], references: [id])
  product     Product @relation(fields: [productId], references: [id])
  request     Request @relation(fields: [requestId], references: [id])
  offer       RequestOffer @relation(fields: [offerId], references: [id])
  buyer       User @relation("TransactionBuyer", fields: [buyerId], references: [id])
  seller      User @relation("TransactionSeller", fields: [sellerId], references: [id])
  otps        TransactionOTP[]

  @@index([productId, status], name: "transaction_product_status_idx")
  @@index([buyerId, status], name: "transaction_buyer_status_idx")
  @@index([sellerId, status], name: "transaction_seller_status_idx")
}

model TransactionOTP {
  id           String   @id @default(uuid())
  transactionId String
  generatedForId String
  otpHash      String
  expiresAt    DateTime
  verifiedAt   DateTime?
  invalidatedAt DateTime?
  attemptCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transaction  Transaction @relation(fields: [transactionId], references: [id])
  generatedFor User @relation("TransactionOtpGeneratedFor", fields: [generatedForId], references: [id])

  @@index([transactionId, expiresAt], name: "transaction_otp_lookup_idx")
  @@index([generatedForId], name: "transaction_otp_generated_for_idx")
}

model RequestOfferProduct {
  id        String   @id @default(uuid())
  offerId   String
  productId String
  createdAt DateTime @default(now())

  offer   RequestOffer @relation(fields: [offerId], references: [id])
  product Product      @relation(fields: [productId], references: [id])

  @@unique([offerId, productId], name: "request_offer_product_unique")
  @@index([productId], name: "request_offer_product_product_idx")
}

model RequestVisibleProduct {
  id        String   @id @default(uuid())
  requestId String
  productId String
  createdAt DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([requestId, productId], name: "request_visible_product_unique")
  @@index([productId], name: "request_visible_product_product_idx")
}